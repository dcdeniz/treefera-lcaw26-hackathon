# Through-the-Clouds — MCP/data-layer env (names only; never commit real values).
# Local dev usually just reuses web/.env.local:
#   node --env-file=../../web/.env.local --import tsx src/cli.ts pipeline

# MongoDB Atlas connection string (db: through_the_clouds). Same value as web/.env.local.
MONGODB_URI=

# QGIS-MCP Streamable HTTP endpoint (default below; override if you remap MCP_PORT).
MCP_URL=http://localhost:8100/mcp

# REST API port (mcp/api). Default 4000.
PORT=4000

# Compose port overrides (mcp/compose.yml). Defaults: MCP 8100, REST 18080, noVNC 6080.
# MCP_PORT=8100
# REST_PORT=18080
# QGIS_VNC_PORT=6080
