{
  "name": "ttc-mcp-api",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Through-the-Clouds product-spine REST API over Mongo `through_the_clouds` (runs + geospatial alerts). Local-dev showcase; does NOT replace the Next static-first demo path.",
  "scripts": {
    "dev": "node --env-file-if-exists=../../web/.env.local --import tsx --watch src/server.ts",
    "start": "node --env-file-if-exists=../../web/.env.local --import tsx src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "mongodb": "^6.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
